	<macro name="Yr">
		<eqn>Year</eqn>
		<variables>
			<aux name="Year" access="output">
				<eqn>1</eqn>
				<units>Years</units>
			</aux>
		</variables>
		<view isee:show_pages="false" background="white" page_width="1091" page_height="761" isee:popup_graphs_are_comparative="true" isee:enable_non_negative_highlights="false" type="stock_flow">
			<style color="black" background="white" font_style="normal" font_weight="normal" text_decoration="none" text_align="center" vertical_text_align="center" font_color="black" font_family="Arial" font_size="10pt" padding="2" border_color="black" border_width="thin" border_style="none">
				<stock color="black" background="white" font_family="Segoe UI" label_side="top">
					<shape type="rectangle" width="55" height="45"/>
				</stock>
				<flow color="black" background="white" font_family="Segoe UI" label_side="bottom">
					<shape type="circle" radius="18"/>
				</flow>
				<isee:placeholder color="#228B22" background="white" font_color="#228B22" font_family="Segoe UI" label_side="bottom"/>
				<module color="#EC6555" background="white" font_color="#EC6555" font_family="Segoe UI" label_side="top">
					<shape type="rectangle" width="55" height="45"/>
				</module>
				<aux color="black" background="white" font_family="Segoe UI" label_side="bottom">
					<shape type="circle" radius="18"/>
				</aux>
				<group color="red" background="white" font_color="red" font_family="Segoe UI"/>
				<connector color="#5881C1" background="white" font_color="#5881C1" font_size="9pt" isee:thickness="1"/>
				<text_box color="black" background="white" text_align="left" vertical_text_align="top" font_family="Segoe UI" font_size="12pt"/>
