					<isee:annotation background="#FDF2CD" transparent="true" isee:flat="true" isee:highlight_on_hover="true" popup_corner_radius="1" popup_background_color="#FDF2CD" launcher_label="" show_by_default="true" hide_launcher="true" launch_on_hover="true" x="191.072" y="526.022" width="25" height="25" isee:conditional_immediately_update_on_user_input="true" isee:conditional_use_active_value="true" isee:conditional_entity="meds_effect_switch">
						<launcher_image width="96" height="96" size_to_parent="true">C:/Users/Sally.Thompson.MLCSU/OneDrive - Midlands and Lancashire CSU/Pictures/Icons/info blue white fill.png</launcher_image>
						<popup x="226.616" y="483.968" width="249.708" height="70.2265">
							<text>Adherence is likely to go down if the number of meds is increased. Consider also adjusting adherence percentages</text>
						</popup>
					</isee:annotation>
