			<aux name="disease management reach">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<element subscript="England">
					<eqn>34.7</eqn>
				</element>
				<element subscript="East_of_England">
					<eqn>33.05</eqn>
				</element>
				<element subscript="London">
					<eqn>35.375</eqn>
				</element>
				<element subscript="Midlands">
					<eqn>33.975</eqn>
				</element>
