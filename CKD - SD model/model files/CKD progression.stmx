					<isee:annotation background="#FDF2CD" transparent="true" isee:flat="true" isee:highlight_on_hover="true" popup_corner_radius="1" popup_background_color="#FDF2CD" launcher_label="" show_by_default="false" hide_launcher="false" launch_on_hover="false" x="196.872" y="212.581" width="20" height="20">
