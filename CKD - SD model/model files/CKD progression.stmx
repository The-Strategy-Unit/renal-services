					<table font_size="10pt" isee:start_time="2026" interval="1" report_balances="beginning" report_flows="instantaneous" header_font_size="9pt" width="699.286" height="413.323" isee:export_name="prevalence" isee:mark_for_export="true" title="Prevalence by Stage and Diagnosis State, KRT incidence, mortality &amp; costs">
