					<slider color="#5881C1" font_size="9pt" num_ticks="4" isee:fancy_appearance="false" isee:show_hover_tip="always" input_expands="true" x="2.872" y="509.274" width="193" height="19.614" title="alternative meds effect on SGLT2i rates" isee:navigate_to="false" show_name="true">
						<entity name="medication_effect_on_rates"/>
						<reset_to after="never">0</reset_to>
