			<aux name="cumulative intervention cost">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>RUNCUM(cost_primary_interventions_targeted)</eqn>
				<units>Pound Sterling</units>
			</aux>
			<group name="Interventions" run="false">
				<entity name="calib_sglt2i_diag"/>
				<entity name="calib_sglt2i_undiag"/>
				<entity name="diag_dm_mort_reduction_p_h_th"/>
				<entity name="diag_dm_progress_reduction_p_h_th"/>
				<entity name="diagnosis_improvement_pc"/>
				<entity name="diagnosis_increase_pc"/>
				<entity name="disease_management_adherence"/>
				<entity name="disease_management_impact"/>
				<entity name="disease_management_reach"/>
				<entity name="medication_effect_on_rates"/>
				<entity name="meds_effect_switch"/>
				<entity name="meds_mort_reduction_p_h_th"/>
				<entity name="meds_progress_reduction_p_h_th"/>
				<entity name="new_cases_pa"/>
				<entity name="primary_prevention_effectiveness_pc"/>
				<entity name="primary_prevention_impact"/>
				<entity name="primary_prevention_reach_pc"/>
				<entity name="sglt2_mort_reduct_p_h_th"/>
				<entity name="sglt2_progress_reduct_p_h_th"/>
				<entity name="und_disease_management_adherence"/>
				<entity name="und_disease_management_impact"/>
				<entity name="und_disease_management_reach"/>
				<entity name="und_dm_mort_reduction_p_h_th"/>
				<entity name="und_dm_progress_reduction_p_h_th"/>
			</group>
			<aux name="pc diag on meds">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>num_diag_on_meds/total_diag_not_KRT * 100</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="pc undiag on meds">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>num_undiag_on_meds/total_undiag * 100</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="meds intervention cost diff from baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>cost_meds - &quot;cost_meds:_baseline&quot;</eqn>
				<format precision="1" scale_by="1"/>
				<units>£/year</units>
			</aux>
			<aux name="cost meds: baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>HISTORY(cost_meds,  TIME,  1)</eqn>
				<units>£/year</units>
			</aux>
			<aux name="Yr offset">
				<eqn>INT(TIME) + 1</eqn>
				<format precision="1" scale_by="1"/>
				<units>Years</units>
			</aux>
			<aux name="costs pc stage 3 pp pa">
				<eqn>6346</eqn>
				<units>£/person/year</units>
			</aux>
			<aux name="costs pc stage 4-5 pp pa">
				<eqn>9963</eqn>
				<units>£/person/year</units>
			</aux>
			<aux name="cost pc stage 3 diag">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>costs_pc_stage_3_pp_pa * CKD_3</eqn>
				<units>£/year</units>
			</aux>
			<aux name="cost pc stage 4-5 diag">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;costs_pc_stage_4-5_pp_pa&quot; * &quot;CKD_4-5_not_KRT&quot;</eqn>
				<units>£/year</units>
			</aux>
			<aux name="cost primary care diag">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>cost_pc_stage_3_diag + &quot;cost_pc_stage_4-5_diag&quot;</eqn>
				<format precision="1" scale_by="1"/>
				<units>£/year</units>
			</aux>
			<aux name="cost combined meds\nand pc stages 3-5">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>cost_primary_care_diag + cost_meds + cost_primary_care_undiag</eqn>
				<format precision="1" scale_by="1"/>
				<isee:summing/>
				<units>£/year</units>
			</aux>
			<aux name="cost primary care undiag" isee:derived_units="true">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;cost_pc_s4-5_undiag&quot; + cost_pc_s3_undiag</eqn>
				<format precision="1" scale_by="1"/>
				<units>£/year</units>
			</aux>
			<aux name="cost pc s3 undiag">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>costs_pc_stage_3_pp_pa
 * und_S3</eqn>
				<units>£/year</units>
			</aux>
			<aux name="cost pc s4-5 undiag">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;costs_pc_stage_4-5_pp_pa&quot;
 * &quot;und_S4-5&quot;</eqn>
				<units>£/year</units>
			</aux>
			<aux name="cost primary care" isee:derived_units="true">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>cost_primary_care_undiag + cost_primary_care_diag</eqn>
				<format precision="1" scale_by="1"/>
				<isee:summing/>
				<units>£/year</units>
			</aux>
			<aux name="Stage 3" isee:derived_units="true">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>CKD_3 + und_S3</eqn>
				<isee:summing/>
				<units>People</units>
			</aux>
			<aux name="Stage 4-5" isee:derived_units="true">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;CKD_4-5_not_KRT&quot; + &quot;und_S4-5&quot;</eqn>
				<isee:summing/>
				<units>People</units>
			</aux>
			<aux name="utility S3">
				<eqn>0.8034</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="utility S4-5">
				<eqn>.7384</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="utility KRT">
				<doc>weighted average of HJEOR figures:

40% are transplant - utility 0.8 (derived)
60% dialysis - utility 0.5836

0.4 * 0.8 + .6 * 0.5836</doc>
				<eqn>.62</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="QALY S3">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>utility_S3 *Stage_3</eqn>
				<units>People</units>
			</aux>
			<aux name="QALY S4-5">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;utility_S4-5&quot; * &quot;Stage_4-5&quot;</eqn>
				<units>People</units>
			</aux>
			<aux name="QALY KRT">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>utility_KRT * KRT</eqn>
				<units>People</units>
			</aux>
			<aux name="QALY CKD KRT">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>QALY_KRT + QALY_S3 + &quot;QALY_S4-5&quot;</eqn>
				<isee:summing/>
				<units>People</units>
			</aux>
			<aux name="QALY cumul diff from baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>QALY_cumul - &quot;QALY_cumul:_baseline&quot;</eqn>
				<format precision="1"/>
				<units>People*Years</units>
			</aux>
			<aux name="QALY display">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>IF 
QALY_cumul_diff_from_baseline &lt; 1 
THEN 0
 ELSE QALY_cumul_diff_from_baseline</eqn>
				<units>People*Years</units>
			</aux>
			<aux name="cost pc: baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>HISTORY(cost_primary_care,  TIME,  1)</eqn>
				<units>£/year</units>
			</aux>
			<aux name="cost pc meds diff from baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;cost_combined_meds_and_pc_stages_3-5&quot; - &quot;cost_pc_meds:_baseline&quot;</eqn>
				<units>£/year</units>
			</aux>
			<aux name="cost pc meds: baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>HISTORY(&quot;cost_combined_meds_and_pc_stages_3-5&quot;,  TIME,  1)</eqn>
				<units>£/year</units>
			</aux>
			<aux name="cost pc diff from baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>cost_primary_care - &quot;cost_pc:_baseline&quot;</eqn>
				<units>£/year</units>
			</aux>
			<aux name="healthy pop">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>ons_pop - model_prev</eqn>
				<units>People</units>
			</aux>
			<aux name="QALY total">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>QALY_CKD_KRT + QALY_healthy</eqn>
				<units>People</units>
			</aux>
			<aux name="utility healthy">
				<eqn>0.8534</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="QALY healthy">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>healthy_pop * utility_healthy</eqn>
				<units>People</units>
			</aux>
			<aux name="mort cumul: baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>HISTORY(mort_cumul,  TIME,  1)</eqn>
				<units>People</units>
			</aux>
			<aux name="cumul mortality difference\nfrom baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>mort_cumul - &quot;mort_cumul:_baseline&quot;</eqn>
				<units>People</units>
			</aux>
			<aux name="model prev: baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>HISTORY(model_prev,  TIME,  1)</eqn>
				<units>People</units>
			</aux>
			<aux name="prevalence diff from baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>model_prev - &quot;model_prev:_baseline&quot;</eqn>
				<units>People</units>
			</aux>
			<aux name="total costs: baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>HISTORY(total_costs,  TIME,  1)</eqn>
				<units>£/year</units>
			</aux>
			<aux name="costs diff from baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>total_costs - &quot;total_costs:_baseline&quot;</eqn>
				<units>£/year</units>
			</aux>
			<aux name="QALY cumul">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>RUNCUM(QALY_total)</eqn>
				<units>People*Years</units>
			</aux>
			<aux name="QALY cumul: baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>HISTORY(QALY_cumul,  TIME,  1)</eqn>
				<units>People*Years</units>
			</aux>
			<aux name="mort cumul">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>RUNCUM(model_mort)</eqn>
				<units>People</units>
			</aux>
			<aux name="percent change costs">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>costs_diff_from_baseline / &quot;total_costs:_baseline&quot; * 100</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="percent change pc">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>cost_pc_diff_from_baseline / &quot;cost_pc:_baseline&quot; * 100</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="percent change pc meds">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>cost_pc_meds_diff_from_baseline / &quot;cost_pc_meds:_baseline&quot; * 100</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="percent change KRT">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>cost_KRT_diff_from_baseline / &quot;cost_KRT:_baseline&quot; * 100</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="cost KRT: baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>HISTORY(cost_total_KRT,  TIME,  1)</eqn>
				<units>£/year</units>
			</aux>
			<aux name="cost KRT diff from baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>cost_total_KRT - &quot;cost_KRT:_baseline&quot;</eqn>
				<units>£/year</units>
			</aux>
			<aux name="percent change meds">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>meds_intervention_cost_diff_from_baseline / &quot;cost_meds:_baseline&quot; * 100</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="QALY CKD cumul">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>QALY_CKD_KRT</eqn>
				<units>People</units>
			</aux>
			<aux name="QALY CKD cumul: baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>HISTORY(QALY_CKD_cumul,  TIME,  1)</eqn>
				<units>People</units>
			</aux>
			<aux name="QALY CKD diff from baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>QALY_CKD_cumul - &quot;QALY_CKD_cumul:_baseline&quot;</eqn>
				<units>People</units>
			</aux>
			<aux name="r und 3 to 4-5">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>MAX(&quot;calib_und_r_3_to_4-5&quot;- und_dm_progress_reduction_p_h_th, 
(&quot;calib_und_r_3_to_4-5&quot;[England] - und_dm_progress_reduction_p_h_th)/10)</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="r 3 to 4-5">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;calib_r3_to_4-5&quot; - diag_dm_progress_reduction_p_h_th</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="r 4-5 to KRT">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;calib_r4-5_to_KRT&quot; - diag_dm_progress_reduction_p_h_th</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="r S3 mort">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>S3_mort_factor * CVD_all_cause_mortality_p_h_th - diag_dm_mort_reduction_p_h_th</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="r S4-5 mort">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;S4-5_mort_factor&quot; * CVD_all_cause_mortality_p_h_th - diag_dm_mort_reduction_p_h_th</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="mort: baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>HISTORY(model_mort,  TIME,  1)</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="mort diff from baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>model_mort - &quot;mort:_baseline&quot;</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="costs excl KRT" isee:derived_units="true">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>cost_primary_care + cost_meds + cost_primary_interventions_targeted</eqn>
				<isee:summing/>
				<units>£/year</units>
			</aux>
			<aux name="costs excl KRT: baseline">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>HISTORY(costs_excl_KRT,  TIME,  1)</eqn>
				<units>£/year</units>
			</aux>
			<aux name="wt CVDP diag mort">
