					<eqn>35.1</eqn>
				</element>
				<element subscript="South_West">
					<eqn>33</eqn>
				</element>
				<format precision="1"/>
				<scale min="0" max="100"/>
				<range min="0" max="100"/>
				<units>dmnl</units>
			</aux>
			<aux name="disease management\nadherence">
				<eqn>60</eqn>
				<format precision="1"/>
				<scale min="0" max="100"/>
				<range min="0" max="100"/>
				<units>dmnl</units>
			</aux>
			<aux name="new cases pa">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>baseline_new_cases_pa * (1-primary_prevention_impact)</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="primary prevention impact">
				<eqn>IF TIME &gt;lead_time
THEN
primary_prevention_reach_pc/100 * primary_prevention_effectiveness_pc/100
ELSE 0</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="primary prevention\nreach pc">
				<eqn>0</eqn>
				<scale min="0" max="100"/>
				<range min="0" max="100"/>
				<units>dmnl</units>
			</aux>
			<flow name="S4-5 to KRT">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>(&quot;CKD_4-5_not_KRT&quot;- &quot;diag_4-5_mort&quot;*Yr)  * &quot;r_4-5_to_KRT&quot;/100000</eqn>
				<format precision="1" scale_by="1"/>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<aux name="diag mort" isee:derived_units="true">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>diag_3_mort + &quot;diag_4-5_mort&quot; + diag_KRT_mort</eqn>
				<format precision="1" scale_by="1"/>
				<isee:summing/>
				<units>People/Years</units>
			</aux>
			<aux name="model mortality">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>model_mort/model_prev *100000</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="diagnosis increase pc">
				<eqn>0</eqn>
				<scale min="0" max="100"/>
				<range min="0" max="100"/>
				<units>dmnl</units>
			</aux>
			<aux name="disease management impact">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>IF TIME &gt;lead_time
THEN
disease_management_reach/100 * 
disease_management_adherence/100
ELSE calib_sglt2i_diag * disease_management_adherence/100</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="und disease\nmanagement reach">
				<eqn>20</eqn>
				<format precision="1"/>
				<scale min="0" max="100"/>
				<range min="0" max="100"/>
				<units>dmnl</units>
			</aux>
			<aux name="und disease management\nadherence">
				<eqn>60</eqn>
				<format precision="1"/>
				<scale min="0" max="100"/>
				<range min="0" max="100"/>
				<units>dmnl</units>
			</aux>
			<aux name="und disease management impact">
				<eqn>IF TIME &gt;lead_time
THEN
und_disease_management_reach/100 * 
und_disease_management_adherence/100
ELSE  calib_sglt2i_undiag * und_disease_management_adherence/100</eqn>
				<units>dmnl</units>
			</aux>
			<group name="Model data" run="false">
				<entity name='"model_prev:_baseline"'/>
				<entity name='"mort:_baseline"'/>
				<entity name='"mort_cumul:_baseline"'/>
				<entity name="cumul_mortality_difference_from_baseline"/>
				<entity name="derived_diag_rate"/>
				<entity name="diag_mort"/>
				<entity name="hi_level_mort"/>
				<entity name="hi_level_mort_p_h_th"/>
				<entity name="hi_level_prev"/>
				<entity name="KRT_incid"/>
				<entity name="KRT_incid_whole_pop"/>
				<entity name="model_diag"/>
				<entity name="model_diag_prev_rate"/>
				<entity name="model_mort"/>
				<entity name="model_mortality"/>
				<entity name="model_mortality_p_h_th"/>
				<entity name="model_prev"/>
				<entity name="model_total_prev_rate"/>
				<entity name="model_undiag"/>
				<entity name="mort_cumul"/>
				<entity name="mort_diff_from_baseline"/>
				<entity name="newly_diagnosed_pa"/>
				<entity name="prevalence_diff_from_baseline"/>
				<entity name="S3_diag_pc"/>
				<entity name="undiag_model_mort"/>
			</group>
			<aux name="undiag model mort" isee:derived_units="true">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>und_3_mort + &quot;und_4-5_mort&quot;</eqn>
				<format precision="1" scale_by="1"/>
				<isee:summing/>
				<units>People/Years</units>
			</aux>
			<aux name="CVDP diag prev rate">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;CVDP_diag_S3-5&quot;/ons_pop *100</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="model diag prev rate">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>model_diag/ons_pop *100</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="model total prev rate">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>model_prev/ons_pop *100</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="CVDP prev rate">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;CVDP_total_prev_S3-5&quot;/ons_pop*100</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="diag dm mort\nreduction p h th">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>disease_management_impact * meds_mort_reduction_p_h_th</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="diag dm progress\nreduction p h th">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>disease_management_impact * meds_progress_reduction_p_h_th</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="und dm mort reduction p h th">
				<eqn>und_disease_management_impact * meds_mort_reduction_p_h_th</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="und dm progress\nreduction p h th">
				<eqn>und_disease_management_impact * meds_progress_reduction_p_h_th</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="sglt2 progress reduct p h th">
				<eqn>1380</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="sglt2 mort reduct p h th">
				<eqn>470</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="lead time">
				<eqn>2026.0</eqn>
				<units>Years</units>
			</aux>
			<aux name="diagnosis improvement pc">
				<eqn>IF TIME &gt;lead_time
THEN 
diagnosis_increase_pc
ELSE 0</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="S3 mort factor">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;nckda_s3_ratio_to_s4-5&quot; * &quot;S4-5_mort_factor&quot;</eqn>
				<format precision="0.01"/>
				<units>dmnl</units>
			</aux>
			<aux name="S4-5 mort factor">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;nckda_s4-5_rate&quot; / CVD_all_cause_mortality_p_h_th</eqn>
				<format precision="0.01"/>
				<units>dmnl</units>
			</aux>
			<aux name="KRT mort factor">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<element subscript="England">
					<eqn>2.05036</eqn>
				</element>
				<element subscript="East_of_England">
					<eqn>2.65451</eqn>
				</element>
				<element subscript="London">
					<eqn>2.13921</eqn>
				</element>
				<element subscript="Midlands">
					<eqn>2.5</eqn>
				</element>
				<element subscript="North_East_and_Yorkshire">
					<eqn>2.06813</eqn>
				</element>
				<element subscript="North_West">
					<eqn>1.74829</eqn>
				</element>
				<element subscript="South_East">
					<eqn>2.5</eqn>
				</element>
				<element subscript="South_West">
					<eqn>2.5</eqn>
				</element>
				<units>dmnl</units>
			</aux>
			<aux name="approx KRT incid rate p h th">
				<eqn>12</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="KRT incid whole pop">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>KRT_incid/ons_pop * 100000</eqn>
				<units>Per Year</units>
			</aux>
			<group name="rates gen pop" run="false">
				<entity name='"adj_r4-5_diag"'/>
				<entity name='"adj_r4-5_to_KRT"'/>
				<entity name='"adj_r_undS3_to_4-5"'/>
				<entity name='"adj_rS3_to_4-5"'/>
				<entity name='"adj_rS4-5_mort"'/>
				<entity name='"adj_und_rS4-5_mort"'/>
				<entity name='"r4-5_diag_pop"'/>
				<entity name='"s3_to_s4-5_rate_pop"'/>
				<entity name='"s4-5_mort_pop"'/>
				<entity name='"s4-5_to_KRT_rate_pop"'/>
				<entity name='"und_s3_to_4-5_rate_pop"'/>
				<entity name='"und_S4-5_rate_pop"'/>
				<entity name="adj_incid"/>
				<entity name="adj_r3_diag"/>
				<entity name="adj_rKRT_mort"/>
				<entity name="adj_rS3_mort"/>
				<entity name="adj_und_rS3_mort"/>
				<entity name="CVDP_diag_prev_rate"/>
				<entity name="KRT_mort_pop"/>
				<entity name="r3_diag_pop"/>
				<entity name="s3_mort_pop"/>
				<entity name="und_s3_rate_pop"/>
			</group>
			<aux name="adj r undS3 to 4-5">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;calib_und_r_3_to_4-5&quot;-und_dm_progress_reduction_p_h_th</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="adj und rS4-5 mort">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>und_dm_mort_reduction_p_h_th</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="adj und rS3 mort">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>-und_dm_mort_reduction_p_h_th</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="adj r3 diag">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>r3_diag*(100+diagnosis_improvement_pc)/100</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="adj r4-5 diag">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;r4-5_diag&quot;*(100+diagnosis_improvement_pc)/100</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="adj rS3 to 4-5">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;calib_r3_to_4-5&quot;-diag_dm_progress_reduction_p_h_th</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="adj r4-5 to KRT">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;calib_r4-5_to_KRT&quot;-diag_dm_progress_reduction_p_h_th</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="adj rS3 mort">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>-diag_dm_mort_reduction_p_h_th</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="adj rKRT mort">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>r_KRT_mort-diag_dm_mort_reduction_p_h_th</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="adj incid">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>100000 * new_cases_pa/ons_pop</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="medication effect on rates">
				<eqn>1</eqn>
				<format precision="0.1"/>
				<scale min="0" max="3"/>
				<range min="0" max="3"/>
				<units>dmnl</units>
			</aux>
			<aux name="meds mort reduction p h th">
				<eqn>medication_effect_on_rates * sglt2_mort_reduct_p_h_th</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="meds progress\nreduction p h th">
				<eqn>sglt2_progress_reduct_p_h_th * medication_effect_on_rates</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="hi level mort" isee:derived_units="true">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>all_undiag_mort + all_diag_mort</eqn>
				<isee:summing/>
				<units>People/Years</units>
			</aux>
			<aux name="hi level prev" isee:derived_units="true">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>undiagnosed + diagnosed</eqn>
				<isee:summing/>
				<units>People</units>
			</aux>
			<aux name="hi level mort p h th">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>hi_level_mort/hi_level_prev * 100000</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="meds effect switch">
				<eqn>IF medication_effect_on_rates = 1 THEN 
0
ELSE 1</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="und S4-5 rate pop">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>100000 * &quot;adj_und_rS4-5_mort&quot;/ons_pop</eqn>
				<units>1/(People*Years)</units>
			</aux>
			<aux name="und s3 rate pop">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>100000 * adj_und_rS3_mort/ons_pop</eqn>
				<units>1/(People*Years)</units>
			</aux>
			<aux name="s3 to s4-5 rate pop">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>100000 * &quot;adj_rS3_to_4-5&quot;/ons_pop</eqn>
				<units>1/(People*Years)</units>
			</aux>
			<aux name="s4-5 to KRT rate pop">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>100000 * &quot;adj_r4-5_to_KRT&quot;/ons_pop</eqn>
				<units>1/(People*Years)</units>
			</aux>
			<aux name="s3 mort pop">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>100000 * adj_rS3_mort/ons_pop</eqn>
				<units>1/(People*Years)</units>
			</aux>
			<aux name="s4-5 mort pop">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>100000 * &quot;adj_rS4-5_mort&quot;/ons_pop</eqn>
				<units>1/(People*Years)</units>
			</aux>
			<aux name="KRT mort pop">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>100000 * adj_rKRT_mort/ons_pop</eqn>
				<units>1/(People*Years)</units>
			</aux>
			<aux name="und s3 to 4-5 rate pop">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>100000 * &quot;adj_r_undS3_to_4-5&quot;/ons_pop</eqn>
				<units>1/(People*Years)</units>
			</aux>
			<aux name="r3 diag pop">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>100000 * adj_r3_diag/ons_pop</eqn>
				<units>1/(People*Years)</units>
			</aux>
			<aux name="r4-5 diag pop">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>100000 * &quot;adj_r4-5_diag&quot;/ons_pop</eqn>
				<units>1/(People*Years)</units>
			</aux>
