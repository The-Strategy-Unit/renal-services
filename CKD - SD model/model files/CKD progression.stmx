			<isee:payoff_element name="model_undiag[*]" weight="8.49378523864038e-10" computed_weights="8.49378523864038e-10,1.55775895466705e-8,1.57376835728912e-8,2.70340732838455e-8,4.42429904021556e-8,2.14433960262153e-7,3.32736335724892e-8,3.35999869014616e-8" compare_name='"CVDP_und_S3-5"[*]' compare_run="-2" tolerance="0" type="ls"/>
