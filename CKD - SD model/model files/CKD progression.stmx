	</isee:payoff_specs_list>
	<model_units>
		<unit name="People">
			<eqn/>
			<alias>person</alias>
			<alias>persons</alias>
		</unit>
		<unit name="Pound Sterling">
			<eqn/>
			<alias>GBP</alias>
			<alias>£</alias>
			<alias>uk pound</alias>
			<alias>uk pounds</alias>
		</unit>
		<unit name="Quarters">
			<eqn/>
			<alias>qtr</alias>
			<alias>quarter</alias>
		</unit>
		<unit name="Years">
			<eqn/>
			<alias>yr</alias>
			<alias>year</alias>
		</unit>
		<unit name="Per Quarter">
			<eqn>1/Quarters</eqn>
		</unit>
		<unit name="Per Year">
			<eqn>1/Years</eqn>
		</unit>
		<unit name="Dimensionless">
			<eqn>1</eqn>
			<alias>dmnl</alias>
			<alias>unitless</alias>
		</unit>
		<unit name="kilowatt hours per day">
			<eqn>kWh/day</eqn>
		</unit>
		<unit name="kilowatts">
			<eqn>kW</eqn>
			<alias>kilowatt</alias>
		</unit>
	</model_units>
	<model>
		<variables>
			<stock name="und S3">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>INIT(CVDP_und_S3)</eqn>
				<format precision="1" scale_by="1"/>
				<inflow>und_new_cases</inflow>
				<outflow>&quot;und_T3_to_4-5&quot;</outflow>
				<outflow>und_3_mort</outflow>
				<outflow>S3_diag</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<stock name="und S4-5">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>INIT(&quot;CVDP_und_S4-5&quot;)</eqn>
				<format precision="1" scale_by="1"/>
				<inflow>&quot;und_T3_to_4-5&quot;</inflow>
				<outflow>&quot;S4-5_diag&quot;</outflow>
				<outflow>&quot;und_4-5_mort&quot;</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<stock name="CKD 3">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>INIT(CVDP_diag_S3)</eqn>
				<format precision="1" scale_by="1"/>
				<inflow>S3_diag</inflow>
				<outflow>&quot;S3_to_4-5&quot;</outflow>
				<outflow>diag_3_mort</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<stock name="CKD 4-5 not KRT">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>INIT(&quot;CVDP_diag_S4-5_exc_KRT&quot;)</eqn>
				<format precision="1" scale_by="1"/>
				<inflow>&quot;S4-5_diag&quot;</inflow>
				<inflow>&quot;S3_to_4-5&quot;</inflow>
				<outflow>&quot;diag_4-5_mort&quot;</outflow>
				<outflow>&quot;S4-5_to_KRT&quot;</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<flow name="und new cases">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>new_cases_pa</eqn>
				<format precision="1"/>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<flow name="und T3 to 4-5">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>(und_S3 - (und_3_mort + S3_diag) * Yr) *&quot;r_und_3_to_4-5&quot;/100000</eqn>
				<format precision="1"/>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<flow name="S3 diag">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>(und_S3 * r3_diag / 100000) * (1 + diagnosis_improvement_pc/100)</eqn>
				<format precision="1"/>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<flow name="S4-5 diag">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>(&quot;und_S4-5&quot; * &quot;r4-5_diag&quot; / 100000) * (1 + diagnosis_improvement_pc/100)</eqn>
				<format precision="1"/>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<flow name="S3 to 4-5">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>(CKD_3 - diag_3_mort*Yr) * &quot;r_3_to_4-5&quot;/100000</eqn>
				<format precision="1"/>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<flow name="und 3 mort">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>und_S3 * r_und_s3_mort/100000</eqn>
				<format precision="1"/>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<flow name="und 4-5 mort">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;und_S4-5&quot; * &quot;r_und_s4-5_mort&quot;/100000</eqn>
				<format precision="1"/>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<flow name="diag 3 mort">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>CKD_3 * r_S3_mort/100000</eqn>
				<format precision="1"/>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<flow name="diag 4-5 mort">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>&quot;CKD_4-5_not_KRT&quot; *&quot;r_S4-5_mort&quot;/100000</eqn>
				<format precision="1"/>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<aux name="incidence rate p h th">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<element subscript="England">
					<eqn>429.128019772907</eqn>
				</element>
				<element subscript="East_of_England">
					<eqn>540.357325181139</eqn>
				</element>
				<element subscript="London">
					<eqn>396.038645861837</eqn>
				</element>
				<element subscript="Midlands">
					<eqn>391.338846005351</eqn>
				</element>
				<element subscript="North_East_and_Yorkshire">
					<eqn>412.105628968193</eqn>
				</element>
				<element subscript="North_West">
					<eqn>333.635365287783</eqn>
				</element>
				<element subscript="South_East">
					<eqn>471.328722123901</eqn>
				</element>
				<element subscript="South_West">
					<eqn>494.831277619379</eqn>
				</element>
				<range min="0" max="1500"/>
				<units>Per Year</units>
			</aux>
			<stock name="undiagnosed">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>INIT(&quot;CVDP_und_S3-5&quot;)</eqn>
				<format precision="1" scale_by="1"/>
				<inflow>exp_incidence</inflow>
				<outflow>new_diagnoses</outflow>
				<outflow>all_undiag_mort</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<stock name="diagnosed">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>INIT(&quot;CVDP_diag_S3-5&quot;)</eqn>
				<format precision="1" scale_by="1"/>
				<inflow>new_diagnoses</inflow>
				<outflow>all_diag_mort</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<flow name="new diagnoses">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>undiagnosed * diagnosis_rate_p_h_th/100000</eqn>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<flow name="all diag mort">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>diagnosed * CVD_all_cause_mortality_p_h_th/100000</eqn>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<flow name="all undiag mort">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>(undiagnosed - new_diagnoses*Yr) * CVD_all_cause_mortality_p_h_th/100000</eqn>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<flow name="exp incidence">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>ons_pop * incidence_rate_p_h_th / 100000</eqn>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<aux name="diagnosis rate p h th">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<element subscript="England">
					<eqn>24370.8378476534</eqn>
				</element>
				<element subscript="East_of_England">
					<eqn>20161.4757369275</eqn>
				</element>
				<element subscript="London">
					<eqn>27970.5631027789</eqn>
				</element>
				<element subscript="Midlands">
					<eqn>28808.8369736017</eqn>
				</element>
				<element subscript="North_East_and_Yorkshire">
					<eqn>20848.6798313654</eqn>
				</element>
				<element subscript="North_West">
					<eqn>25836.4501965891</eqn>
				</element>
				<element subscript="South_East">
					<eqn>23797.4603800634</eqn>
				</element>
				<element subscript="South_West">
					<eqn>22823.1241392663</eqn>
				</element>
				<units>Per Year</units>
			</aux>
			<aux name="model undiag">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>und_S3 + &quot;und_S4-5&quot;</eqn>
				<isee:summing/>
				<units>People</units>
			</aux>
			<aux name="model diag">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>CKD_3 + &quot;CKD_4-5_not_KRT&quot; + KRT</eqn>
				<isee:summing/>
				<units>People</units>
			</aux>
			<stock name="KRT">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>INIT(UKRR_KRT)</eqn>
				<format precision="1" scale_by="1"/>
				<inflow>&quot;S4-5_to_KRT&quot;</inflow>
				<outflow>diag_KRT_mort</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<flow name="diag KRT mort">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<eqn>(KRT * r_KRT_mort/100000)</eqn>
				<format precision="1"/>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<group name="Calibration with\nCVD Prevent" run="false">
				<entity name="all_diag_mort"/>
				<entity name="all_undiag_mort"/>
				<entity name="calib_total_prev"/>
				<entity name="diagnosed"/>
				<entity name="diagnosis_rate_p_h_th"/>
				<entity name="exp_incidence"/>
				<entity name="incidence_rate_p_h_th"/>
				<entity name="new_diagnoses"/>
				<entity name="ons_pop"/>
				<entity name="pc_diagnosed"/>
				<entity name="total_prev_pc"/>
				<entity name="undiagnosed"/>
			</group>
			<aux name="ons pop">
				<dimensions>
					<dim name="region"/>
				</dimensions>
				<element subscript="England">
					<gf>
						<xscale min="2022.5" max="2043.5"/>
						<yscale min="0" max="60000000"/>
						<ypts>45243128,45872994,46437085,47023092,47368251,47703071,48063978,48456988,48854548,49228943,49580840,49923866,50267597,50588385,50888836,51176454,51449042,51698406,51948189,52162336,52371064,52577848</ypts>
					</gf>
				</element>
				<element subscript="East_of_England">
					<gf>
						<xscale min="2022.5" max="2043.5"/>
						<yscale min="0" max="100"/>
						<ypts>5053426,5119145,5182280,5231172,5273828,5315144,5358489,5404569,5451181,5495520,5538026,5579944,5622678,5662134,5700149,5736361,5771617,5803848,5837182,5865787,5894297,5922701</ypts>
					</gf>
				</element>
				<element subscript="London">
					<gf>
						<xscale min="2022.5" max="2043.5"/>
						<yscale min="0" max="100"/>
						<ypts>6969092,7088056,7173650,7391310,7428272,7463444,7506100,7558574,7613864,7666137,7715930,7765215,7814787,7860400,7901990,7941220,7978061,8010911,8043867,8070248,8095054,8118478</ypts>
					</gf>
				</element>
				<element subscript="Midlands">
					<gf>
						<xscale min="2022.5" max="2043.5"/>
						<yscale min="0" max="100"/>
						<ypts>8644547,8759554,8866993,8962622,9030024,9095055,9163632,9238795,9314175,9385060,9451121,9514126,9577454,9637277,9693596,9747310,9798691,9845936,9893299,9934170,9973847,10013691</ypts>
					</gf>
				</element>
				<element subscript="North_East_and_Yorkshire">
